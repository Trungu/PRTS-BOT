# COLLABORATORS PLEASE READ THIS FILE
# INSTRUCTIONS FOR WRITING YOUR .env FILE

# send me a DM if you need the discord token

# IMPORTANT
DISCORD_TOKEN=your_bot_token_here
LLM_API_KEY=your_llm_api_token_here
LLM_BASE_URL=http://localhost:8080/v1 # example url
LLM_MODEL=llama3 # example model

# Bot Prefix
BOT_PREFIX=bot
# Smart characters: pipe-separated suffixes that also trigger the prefix
# e.g. 'bot ' | 'bot, ' | 'bot. '
PREFIX_SMART_CHARS= |, |. 
# Whether the prefix match is case-sensitive (true/false)
PREFIX_CASE_SENSITIVE=false


# If True, tool-call notification messages are sent as silent Discord messages
# (suppress notifications — the bell-with-slash icon). Users still see them.
# Set TOOLCALL_SILENT=true in .env to enable.
TOOLCALL_SILENT=True

# If True, EVERY message the bot sends (replies, tool notices, errors) is silent.
# Overrides TOOLCALL_SILENT. Set GLOBAL_SILENT=true in .env to enable.
GLOBAL_SILENT=True

# If True, long replies are split at natural language boundaries (paragraph break,
# sentence end, word boundary) instead of a hard 2000-char chop.
# Safe to disable — messages will still be split at 2000 chars, they just won't
# look for a clean break point.
SMART_CUTOFF=true

# Google Calendar / OAuth
CLIENT_ID=your_google_oauth_client_id_here
CLIENT_SECRET=your_google_oauth_client_secret_here
OAUTH_BASE_URL=http://localhost:8000
OAUTH_REDIRECT_URI=http://localhost:8000/callback
# Optional; defaults to ./gcal.sqlite3
GCAL_DB_PATH=
