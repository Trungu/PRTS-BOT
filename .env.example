# COLLABORATORS PLEASE READ THIS FILE
# INSTRUCTIONS FOR WRITING YOUR .env FILE

# send me a DM if you need the discord token

# IMPORTANT — only secrets go here; all other config lives in settings.py
DISCORD_TOKEN=your_bot_token_here

# LLM provider
# Leave LLM_PROVIDER unset or set it to `groq` for the current default hosted mode.
# Set LLM_PROVIDER=ollama to use a local Ollama server instead.
LLM_PROVIDER=groq

# Groq example
LLM_API_KEY=your_groq_api_key_here
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=openai/gpt-oss-20b

# Ollama example
# LLM_PROVIDER=ollama
# LLM_API_KEY=
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1:8b

# Default HTTP timeout for LLM requests in seconds.
LLM_REQUEST_TIMEOUT_SECONDS=120

# Bot Prefix
BOT_PREFIX=bot
# Smart characters: pipe-separated suffixes that also trigger the prefix
# e.g. 'bot ' | 'bot, ' | 'bot. '
PREFIX_SMART_CHARS= |, |. 
# Whether the prefix match is case-sensitive (true/false)
PREFIX_CASE_SENSITIVE=false

# If True, direct replies to bot-authored messages are processed even without prefix.
REPLY_TRIGGER_ENABLED=true

# Default recent prompt context (enabled by default)
# If enabled, each LLM prompt includes a small window of recent channel messages.
RECENT_CONTEXT_ENABLED=true
# Number of recent prior channel messages to inject by default.
RECENT_CONTEXT_MESSAGE_COUNT=10

# Temporary memory (in-memory channel context lookup tool)
# If enabled, the model can fetch recent channel messages for context.
TEMPORARY_MEMORY_ENABLED=false
# Max messages stored per channel in memory.
TEMP_MEMORY_BUFFER_SIZE=200
# Max messages returned per lookup call.
TEMP_MEMORY_MAX_LOOKBACK=60


# If True, tool-call notification messages are sent as silent Discord messages
# (suppress notifications — the bell-with-slash icon). Users still see them.
# Set TOOLCALL_SILENT=true in .env to enable.
TOOLCALL_SILENT=True

# If True, EVERY message the bot sends (replies, tool notices, errors) is silent.
# Overrides TOOLCALL_SILENT. Set GLOBAL_SILENT=true in .env to enable.
GLOBAL_SILENT=True

# If True, long replies are split at natural language boundaries (paragraph break,
# sentence end, word boundary) instead of a hard 2000-char chop.
# Safe to disable — messages will still be split at 2000 chars, they just won't
# look for a clean break point.
SMART_CUTOFF=true

# Google Calendar / OAuth
CLIENT_ID=your_google_oauth_client_id_here
CLIENT_SECRET=your_google_oauth_client_secret_here
OAUTH_BASE_URL=http://localhost:8000
OAUTH_REDIRECT_URI=http://localhost:8000/callback
# Optional; defaults to ./gcal.sqlite3
GCAL_DB_PATH=
